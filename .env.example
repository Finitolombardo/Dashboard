# ============================================================
# Mission Control Frontend - Umgebungsvariablen
# ============================================================

# Backend / API / Quest-SoT
# Wenn gesetzt, wird diese URL als primaere Datenquelle verwendet.
# Das Frontend holt Quest-Daten von tasks.getvoidra.com/api/tasks
VITE_API_BASE_URL=https://tasks.getvoidra.com

# Optional: Supabase (nur als Fallback, wenn VITE_API_BASE_URL nicht gesetzt)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# ============================================================
# Systemlandkarte (nur zur Referenz - nicht als env vars noetig)
# ============================================================
# Frontend / UI:        https://mission-control-ai-o-ywsj.bolt.host  (Haupt-Dashboard)
# Backend / API:        https://tasks.getvoidra.com                   (Quest-SoT, kein Dashboard)
# Quest-Ansicht:        https://tasks.getvoidra.com/tasks             (Backend-Ansicht, kein Frontend)
# Agent-Chat:           https://agent.getvoidra.com/chat?session=agent%3Amain%3Amain
# Legacy (eingefroren): https://mc.getvoidra.com                      -- NICHT nutzen
# ============================================================
